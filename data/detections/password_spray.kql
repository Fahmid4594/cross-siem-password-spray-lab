let Failedlogins =_GetWatchlist("AuthEvents")
| where action == "Failed"
| summarize FailedAccountcount= dcount(username), FailedAccounts = make_set(username) by source_ip |where FailedAccountcount > 5 ;
_GetWatchlist("AuthEvents")
| where action == "Success"
| join kind=inner (Failedlogins) on source_ip